# wt shell integration — zsh (generated by wt shell init zsh)
WT_BIN="{{.WtPath}}"

__wt_chpwd() {
    local cur="$PWD"
    [[ "$cur" == "$__WT_LAST_DIR" ]] && return

    if [[ -n "${__WT_LOADED_ALIASES-}" ]]; then
        eval "$( "$WT_BIN" aliases --unload )"
    fi

    if [[ -n "${__WT_LAST_DIR-}" ]]; then
        ( cd "$__WT_LAST_DIR" && "$WT_BIN" hook run leave 2>/dev/null || true )
    fi

    if alias_out="$( "$WT_BIN" aliases --load 2>/dev/null )"; then
        eval "$alias_out"
        __WT_LOADED_ALIASES=1
        "$WT_BIN" hook run enter 2>/dev/null || true
    else
        unset __WT_LOADED_ALIASES
    fi

    __WT_LAST_DIR="$cur"
}

wt_prompt() {
    "$WT_BIN" prompt 2>/dev/null || true
}

chpwd_functions+=(__wt_chpwd)

# hook into RPS1 / prepend to PROMPT
case "${RPS1:-}" in
    *'$(wt_prompt)'*) ;;
    *) RPS1='$(wt_prompt) '"${RPS1:-}" ;;
esac
