# wt shell integration — bash (generated by wt shell init bash)
WT_BIN="{{.WtPath}}"

__wt_chpwd() {
    local cur="$PWD"
    [[ "$cur" == "$__WT_LAST_DIR" ]] && return

    # unload previous aliases
    if [[ -n "${__WT_LOADED_ALIASES-}" ]]; then
        eval "$( "$WT_BIN" aliases --unload )"
    fi

    # run leave hook
    if [[ -n "${__WT_LAST_DIR-}" ]]; then
        ( cd "$__WT_LAST_DIR" && "$WT_BIN" hook run leave 2>/dev/null || true )
    fi

    # load new aliases + enter hook
    if alias_out="$( "$WT_BIN" aliases --load 2>/dev/null )"; then
        eval "$alias_out"
        __WT_LOADED_ALIASES=1
        "$WT_BIN" hook run enter 2>/dev/null || true
    else
        unset __WT_LOADED_ALIASES
    fi

    __WT_LAST_DIR="$cur"
}

wt_prompt() {
    "$WT_BIN" prompt 2>/dev/null || true
}

if [[ -z "${PROMPT_COMMAND-}" ]]; then
    PROMPT_COMMAND='__wt_chpwd'
else
    PROMPT_COMMAND='__wt_chpwd;'"$PROMPT_COMMAND"
fi

# prepend prompt segment to PS1
case "$PS1" in
    *'$(wt_prompt)'*) ;;
    *) PS1='$(wt_prompt)'"$PS1" ;;
esac
