# wt shell integration — fish (generated by wt shell init fish)
set -g WT_BIN "{{.WtPath}}"

function __wt_on_pwd --on-variable PWD
    set cur "$PWD"
    if test "$cur" = "$__WT_LAST_DIR"
        return
    end

    if set -q __WT_LOADED_ALIASES
        "$WT_BIN" aliases --unload 2>/dev/null | source
    end

    if set -q __WT_LAST_DIR
        cd "$__WT_LAST_DIR"; and "$WT_BIN" hook run leave 2>/dev/null; or true; end

    if "$WT_BIN" aliases --load 2>/dev/null | source
        set -g __WT_LOADED_ALIASES 1
        "$WT_BIN" hook run enter 2>/dev/null; or true
    else
        set -e __WT_LOADED_ALIASES
    end

    set -g __WT_LAST_DIR "$cur"
end
